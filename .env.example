APP_NAME="Rock Code Starter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stack
LOG_LEVEL=debug
DB_CONNECTION=sqlite
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
MEDIA_DISK=public
MEDIA_MAX_SIZE_KB=10240
MEDIA_IMAGE_MAX_WIDTH=2400
MEDIA_IMAGE_QUALITY=82

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SEO_DEFAULT_TITLE="${APP_NAME}"
SEO_TITLE_SUFFIX=" | ${APP_NAME}"
SEO_DEFAULT_DESCRIPTION="Aplicação criada com o Rock Code Project Starter."
SEO_DEFAULT_IMAGE=
SEO_TWITTER_CARD=summary_large_image

GROWTH_ENABLED=false
GROWTH_RETENTION_DAYS=365
GA_ENABLED=false
GA_MEASUREMENT_ID=
VITE_APP_NAME="${APP_NAME}"
VITE_GROWTH_ENABLED="${GROWTH_ENABLED}"
